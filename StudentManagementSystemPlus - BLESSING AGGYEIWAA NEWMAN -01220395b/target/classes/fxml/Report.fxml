<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.PieChart?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="controller.ReportController"
      style="-fx-background-color: #f4f6f8;" spacing="20">

    <!-- Header -->
    <HBox style="-fx-padding: 20; -fx-background-color: white;">
        <!-- FIXED: Changed '&' to '&amp;' -->
        <Label text="Reports &amp; Analytics" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    </HBox>

    <!-- Content -->
    <VBox spacing="20" style="-fx-padding: 20;">

        <!-- Chart Container -->
        <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8;">
            <Label text="Student Status Distribution" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Separator/>

            <!-- The Pie Chart -->
            <PieChart fx:id="statusChart" prefWidth="600" prefHeight="400" labelsVisible="true" legendVisible="true" style="-fx-padding: 10;"/>
        </VBox>

    </VBox>
</VBox>